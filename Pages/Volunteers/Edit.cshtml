@page "{id:int}"
@model Nirvachak_AI.Pages.Volunteers.EditModel
@{
    ViewData["Title"] = "Edit Volunteer";
}
<div class="row justify-content-center">
    <div class="col-md-7">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil-square me-2"></i>Edit Volunteer</div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="Volunteer.Id" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    <div class="row g-3">
                        @if (Model.IsAdmin)
                        {
                            <div class="col-12">
                                <label asp-for="Volunteer.ConstituencyId" class="form-label fw-semibold">Constituency *</label>
                                <select asp-for="Volunteer.ConstituencyId" class="form-select">
                                    @foreach (var c in Model.Constituencies)
                                    {
                                        <option value="@c.Id">@c.Name</option>
                                    }
                                </select>
                            </div>
                        }
                        <div class="col-md-6">
                            <label asp-for="Volunteer.Name" class="form-label fw-semibold">Full Name *</label>
                            <input asp-for="Volunteer.Name" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Volunteer.Phone" class="form-label fw-semibold">Phone *</label>
                            <input asp-for="Volunteer.Phone" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Volunteer.Email" class="form-label fw-semibold">Email</label>
                            <input asp-for="Volunteer.Email" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Volunteer.Task" class="form-label fw-semibold">Task *</label>
                            <select asp-for="Volunteer.Task" class="form-select"
                                asp-items="Html.GetEnumSelectList<VolunteerTask>()"></select>
                        </div>
                        <div class="col-12">
                            <label asp-for="Volunteer.Address" class="form-label fw-semibold">Address</label>
                            <input asp-for="Volunteer.Address" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Volunteer.AssignedArea" class="form-label fw-semibold">Assigned Area</label>
                            <input asp-for="Volunteer.AssignedArea" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Volunteer.AssignedBoothNumbers" class="form-label fw-semibold">Assigned Booths</label>
                            <input asp-for="Volunteer.AssignedBoothNumbers" class="form-control" placeholder="e.g. 1,2,3" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Volunteer.Notes" class="form-label fw-semibold">Notes</label>
                            <textarea asp-for="Volunteer.Notes" class="form-control" rows="2"></textarea>
                        </div>
                        <div class="col-12">
                            <div class="form-check">
                                <input asp-for="Volunteer.IsActive" class="form-check-input" />
                                <label asp-for="Volunteer.IsActive" class="form-check-label fw-semibold">Active</label>
                            </div>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save Changes</button>
                        <a asp-page="/Volunteers/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
