@page
@model ElectionCampaignTool.Pages.Voters.IndexModel
@{
    ViewData["Title"] = "Voter List";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <div>
        <span class="text-muted small">@Model.TotalCount voters found</span>
    </div>
    <div class="d-flex gap-2">
        @if (Model.CanImportCsv)
        {
            <a asp-page="/Voters/Import" class="btn btn-success btn-sm">
                <i class="bi bi-upload me-1"></i>Import CSV
            </a>
        }
        <a asp-page="/VoterSlips/Index" class="btn btn-outline-secondary btn-sm">
            <i class="bi bi-printer me-1"></i>Print Slips
        </a>
    </div>
</div>

<!-- Filters -->
<div class="card mb-3">
    <div class="card-body py-2">
        <form method="get" class="row g-2 align-items-end">
            @if (Model.IsAdmin)
            {
                <div class="col-md-3">
                    <select asp-for="ConstituencyFilter" class="form-select form-select-sm" onchange="this.form.submit()">
                        <option value="">All Constituencies</option>
                        @foreach (var c in Model.Constituencies)
                        {
                            <option value="@c.Id">@c.Name</option>
                        }
                    </select>
                </div>
            }
            <div class="col-md-3">
                <input asp-for="Search" class="form-control form-control-sm" placeholder="Search name / EPIC / mobile..." />
            </div>
            <div class="col-md-2">
                <select asp-for="BoothFilter" class="form-select form-select-sm">
                    <option value="">All Booths</option>
                    @foreach (var b in Model.BoothNumbers)
                    {
                        <option value="@b">Booth @b</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select asp-for="SentimentFilter" class="form-select form-select-sm">
                    <option value="">All Sentiments</option>
                    @foreach (var s in Enum.GetValues<VoterSentiment>())
                    {
                        <option value="@s">@s</option>
                    }
                </select>
            </div>
            <div class="col-md-2">
                <select asp-for="GenderFilter" class="form-select form-select-sm">
                    <option value="">All Genders</option>
                    <option value="M">Male</option>
                    <option value="F">Female</option>
                    <option value="O">Other</option>
                </select>
            </div>
            <div class="col-md-1">
                <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-search"></i></button>
            </div>
            <div class="col-md-1">
                <a asp-page="/Voters/Index" class="btn btn-outline-secondary btn-sm w-100">Reset</a>
            </div>
        </form>
    </div>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>EPIC</th>
                        <th>Name</th>
                        <th>Age/Gender</th>
                        <th>Booth</th>
                        <th>Mobile</th>
                        <th>Sentiment</th>
                        <th>Status</th>
                        <th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var v in Model.Voters)
                {
                    <tr class="voter-@v.Sentiment.ToString().ToLower()">
                        <td class="text-muted small">@v.SerialNumber</td>
                        <td><span class="badge bg-light text-dark font-monospace">@v.VoterId</span></td>
                        <td>
                            <div class="fw-semibold">@v.Name</div>
                            @if (!string.IsNullOrEmpty(v.FatherHusbandName))
                            {
                                <div class="text-muted" style="font-size:0.75rem">S/O @v.FatherHusbandName</div>
                            }
                        </td>
                        <td>@v.Age / @v.Gender</td>
                        <td><span class="badge bg-secondary">@v.BoothNumber</span></td>
                        <td>@(v.MobileNumber ?? "—")</td>
                        <td>
                            <span class="badge badge-@v.Sentiment.ToString().ToLower()">@v.Sentiment</span>
                        </td>
                        <td>
                            @if (v.ElectionDayStatus == ElectionDayStatus.Voted)
                            {
                                <span class="badge bg-success">Voted</span>
                            }
                            else if (v.ElectionDayStatus == ElectionDayStatus.Absent)
                            {
                                <span class="badge bg-secondary">Absent</span>
                            }
                            else
                            {
                                <span class="badge bg-light text-muted">—</span>
                            }
                        </td>
                        <td>
                            <a asp-page="/Voters/Details" asp-route-id="@v.Id" class="btn btn-sm btn-outline-primary py-0 px-2">
                                <i class="bi bi-eye"></i>
                            </a>
                        </td>
                    </tr>
                }
                @if (!Model.Voters.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No voters found. <a asp-page="/Voters/Import">Import voters</a></td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
    <!-- Pagination -->
    @if (Model.TotalPages > 1)
    {
        <div class="card-footer d-flex justify-content-between align-items-center">
            <small class="text-muted">Page @Model.CurrentPage of @Model.TotalPages</small>
            <nav>
                <ul class="pagination pagination-sm mb-0">
                    @for (int p = 1; p <= Model.TotalPages; p++)
                    {
                        <li class="page-item @(p == Model.CurrentPage ? "active" : "")">
                            <a class="page-link" asp-page="/Voters/Index" asp-route-currentPage="@p"
                               asp-route-search="@Model.Search" asp-route-constituencyFilter="@Model.ConstituencyFilter"
                               asp-route-boothFilter="@Model.BoothFilter"
                               asp-route-sentimentFilter="@Model.SentimentFilter" asp-route-genderFilter="@Model.GenderFilter">@p</a>
                        </li>
                    }
                </ul>
            </nav>
        </div>
    }
</div>
