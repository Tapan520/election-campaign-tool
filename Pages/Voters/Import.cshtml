@page
@model Nirvachak_AI.Pages.Voters.ImportModel
@{
    ViewData["Title"] = "Import Voters";
}

<div class="row justify-content-center">
    <div class="col-md-8">
        @if (Model.Result != null)
        {
            if (Model.Result.Success)
            {
                var successMsg = $"Import Complete! {Model.Result.Imported} imported, {Model.Result.Skipped} skipped out of {Model.Result.Total} total rows.";
                <div class="alert alert-success alert-auto-dismiss">
                    <i class="bi bi-check-circle me-2"></i>
                    <strong>@successMsg</strong>
                </div>
            }
            else
            {
                var errorMsg = string.Join(", ", Model.Result.Errors);
                <div class="alert alert-danger alert-auto-dismiss">
                    <i class="bi bi-x-circle me-2"></i>
                    <strong>Import Failed:</strong> @errorMsg
                </div>
            }
        }

        <div class="card mb-4">
            <div class="card-header"><i class="bi bi-upload me-2"></i>Upload Voter CSV File</div>
            <div class="card-body">
                <form method="post" enctype="multipart/form-data">
                    <div class="mb-3">
                        <label class="form-label fw-semibold">Constituency</label>
                        <select asp-for="SelectedConstituencyId" asp-items="Model.ConstituencyItems" class="form-select">
                            <option value="">-- Select Constituency --</option>
                        </select>
                    </div>
                    <div class="mb-3">
                        <label class="form-label fw-semibold">CSV File</label>
                        <input type="file" name="csvFile" accept=".csv" class="form-control" required />
                        <div class="form-text">Upload voter roll in CSV format. Max 50,000 rows per upload.</div>
                    </div>
                    <button type="submit" class="btn btn-success">
                        <i class="bi bi-cloud-upload me-1"></i>Import Voters
                    </button>
                </form>
            </div>
        </div>

        <div class="card">
            <div class="card-header"><i class="bi bi-info-circle me-2"></i>CSV Format Guide</div>
            <div class="card-body">
                <p class="small text-muted mb-2">Your CSV file must have these column headers (first row):</p>
                <div class="table-responsive">
                    <table class="table table-sm table-bordered small">
                        <thead class="table-light">
                            <tr><th>Column</th><th>Required</th><th>Example</th><th>Notes</th></tr>
                        </thead>
                        <tbody>
                            <tr><td><code>VoterId</code></td><td><span class="badge bg-danger">Required</span></td><td>MH01234567</td><td>EPIC number</td></tr>
                            <tr><td><code>Name</code></td><td><span class="badge bg-danger">Required</span></td><td>Rajesh Kumar</td><td>Full name</td></tr>
                            <tr><td><code>Age</code></td><td><span class="badge bg-danger">Required</span></td><td>45</td><td>Age in years</td></tr>
                            <tr><td><code>Gender</code></td><td><span class="badge bg-danger">Required</span></td><td>M</td><td>M / F / O</td></tr>
                            <tr><td><code>Address</code></td><td><span class="badge bg-danger">Required</span></td><td>House 5, Ward 2</td><td>Full address</td></tr>
                            <tr><td><code>BoothNumber</code></td><td><span class="badge bg-danger">Required</span></td><td>3</td><td>Polling booth number</td></tr>
                            <tr><td><code>SerialNumber</code></td><td><span class="badge bg-danger">Required</span></td><td>127</td><td>Serial in voter list</td></tr>
                            <tr><td><code>NameLocal</code></td><td><span class="badge bg-secondary">Optional</span></td><td>????? ?????</td><td>Regional language name</td></tr>
                            <tr><td><code>FatherHusbandName</code></td><td><span class="badge bg-secondary">Optional</span></td><td>Ram Kumar</td><td>Father/Husband name</td></tr>
                            <tr><td><code>MobileNumber</code></td><td><span class="badge bg-secondary">Optional</span></td><td>9876543210</td><td>10-digit mobile</td></tr>
                            <tr><td><code>WardNumber</code></td><td><span class="badge bg-secondary">Optional</span></td><td>5</td><td>Ward number</td></tr>
                            <tr><td><code>PannaNumber</code></td><td><span class="badge bg-secondary">Optional</span></td><td>13</td><td>Panna/Page number</td></tr>
                        </tbody>
                    </table>
                </div>
                <a href="/SampleData/sample_voters.csv" download class="btn btn-sm btn-outline-primary">
                    <i class="bi bi-download me-1"></i>Download Sample CSV
                </a>
            </div>
        </div>
    </div>
</div>
