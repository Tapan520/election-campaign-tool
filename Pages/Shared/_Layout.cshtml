@using Microsoft.AspNetCore.Identity
@using ElectionCampaignTool.Domain.Entities
@inject SignInManager<AppUser> SignInManager
@inject UserManager<AppUser> UserManager
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Election Campaign Tool</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/app.css" asp-append-version="true" />
    <link rel="manifest" href="/manifest.json" />
    <link rel="icon" type="image/png" sizes="192x192" href="/icons/icon-192.png" />
    <link rel="apple-touch-icon" href="/icons/icon-192.png" />
    <meta name="theme-color" content="#3b5bdb" />
    <meta name="mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />
    <meta name="apple-mobile-web-app-title" content="ElectionTool" />
</head>
<body class="d-flex flex-column min-vh-100">

@if (SignInManager.IsSignedIn(User))
{
    var currentUser = await UserManager.GetUserAsync(User);
    var currentPage = ViewContext.RouteData.Values["page"]?.ToString() ?? "";
    <div class="d-flex" id="wrapper">
        <!-- Sidebar -->
        <nav id="sidebar" class="sidebar d-flex flex-column">
            <div class="sidebar-header px-3 py-3 border-bottom border-secondary">
                <div class="d-flex align-items-center">
                    <i class="bi bi-bar-chart-fill text-warning fs-4 me-2"></i>
                    <div>
                        <div class="fw-bold text-white small">Election Campaign</div>
                        <div class="text-muted" style="font-size:0.7rem;">Management Tool</div>
                    </div>
                </div>
            </div>
            <div class="sidebar-body flex-grow-1 overflow-auto py-2">
                <ul class="nav flex-column px-2">
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage == "/Dashboard/Index" ? "active" : "")" asp-page="/Dashboard/Index">
                            <i class="bi bi-speedometer2 me-2"></i> Dashboard
                        </a>
                    </li>
                    <li class="sidebar-section-label px-2 mt-3 mb-1">VOTERS</li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Voters/Index") ? "active" : "")" asp-page="/Voters/Index">
                            <i class="bi bi-people-fill me-2"></i> Voter List
                        </a>
                    </li>
                    @if (currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.FieldWorker && currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.BoothAgent)
                    {
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage == "/Voters/Import" ? "active" : "")" asp-page="/Voters/Import">
                            <i class="bi bi-upload me-2"></i> Import Voters
                        </a>
                    </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage == "/VoterSlips/Index" ? "active" : "")" asp-page="/VoterSlips/Index">
                            <i class="bi bi-printer-fill me-2"></i> Voter Slips
                        </a>
                    </li>
                    <li class="sidebar-section-label px-2 mt-3 mb-1">CAMPAIGN</li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Booths") ? "active" : "")" asp-page="/Booths/Index">
                            <i class="bi bi-geo-alt-fill me-2"></i> Booths
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Campaign") ? "active" : "")" asp-page="/Campaign/Index">
                            <i class="bi bi-calendar-event-fill me-2"></i> Campaign Events
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Volunteers") ? "active" : "")" asp-page="/Volunteers/Index">
                            <i class="bi bi-person-check-fill me-2"></i> Volunteers
                        </a>
                    </li>
                    <li class="sidebar-section-label px-2 mt-3 mb-1">OPERATIONS</li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/ElectionDay") ? "active" : "")" asp-page="/ElectionDay/Index">
                            <i class="bi bi-activity me-2"></i> Election Day
                        </a>
                    </li>
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Analytics") ? "active" : "")" asp-page="/Analytics/Index">
                            <i class="bi bi-bar-chart-line-fill me-2"></i> Analytics
                        </a>
                    </li>
                    @if (currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.FieldWorker && currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.BoothAgent)
                    {
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Grievances") ? "active" : "")" asp-page="/Grievances/Index">
                            <i class="bi bi-exclamation-triangle-fill me-2"></i> Grievances
                        </a>
                    </li>
                    }
                    @if (currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.FieldWorker && currentUser?.Role != ElectionCampaignTool.Domain.Enums.UserRole.BoothAgent)
                    {
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Expenses") ? "active" : "")" asp-page="/Expenses/Index">
                            <i class="bi bi-cash-coin me-2"></i> Expenses
                        </a>
                    </li>
                    }
                    <li class="nav-item">
                        <a class="nav-link sidebar-link @(currentPage.StartsWith("/Surveys") ? "active" : "")" asp-page="/Surveys/Index">
                            <i class="bi bi-clipboard2-data-fill me-2"></i> Surveys &amp; Feedback
                        </a>
                    </li>
                    @if (User.IsInRole("Admin") || User.IsInRole("CampaignManager"))
                    {
                        <li class="sidebar-section-label px-2 mt-3 mb-1">MANAGEMENT</li>
                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item">
                                <a class="nav-link sidebar-link @(currentPage.StartsWith("/Admin/Constituencies") ? "active" : "")" asp-page="/Admin/Constituencies/Index">
                                    <i class="bi bi-geo-fill me-2"></i> Constituencies
                                </a>
                            </li>
                        }
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentPage.StartsWith("/Admin/Wards") ? "active" : "")" asp-page="/Admin/Wards/Index">
                                <i class="bi bi-map me-2"></i> Wards
                            </a>
                        </li>
                        <li class="nav-item">
                            <a class="nav-link sidebar-link @(currentPage.StartsWith("/Admin") && !currentPage.StartsWith("/Admin/Constituencies") && !currentPage.StartsWith("/Admin/Wards") ? "active" : "")" asp-page="/Admin/Index">
                                <i class="bi bi-people me-2"></i> Users
                            </a>
                        </li>
                    }
                </ul>
            </div>
            <div class="sidebar-footer px-3 py-2 border-top border-secondary">
                <div class="d-flex align-items-center justify-content-between">
                    <div class="small text-white">
                        <i class="bi bi-person-circle me-1"></i>
                        @currentUser?.FullName
                        <br/><span class="text-muted" style="font-size:0.7rem;">@currentUser?.Role</span>
                    </div>
                    <form method="post" asp-page="/Account/Logout">
                        <button type="submit" class="btn btn-sm btn-outline-secondary" title="Logout">
                            <i class="bi bi-box-arrow-right"></i>
                        </button>
                    </form>
                </div>
            </div>
        </nav>
        <!-- Page content -->
        <div id="page-content-wrapper" class="flex-grow-1">
            <nav class="navbar navbar-expand navbar-light bg-white border-bottom px-3 py-2">
                <button class="btn btn-sm btn-outline-secondary me-3" id="sidebarToggle">
                    <i class="bi bi-list"></i>
                </button>
                <span class="navbar-text fw-semibold text-dark">@ViewData["Title"]</span>
                <div class="ms-auto d-flex align-items-center gap-2">
                    <span class="badge bg-success">Live</span>
                    <small class="text-muted">@DateTime.Now.ToString("dd MMM yyyy")</small>
                </div>
            </nav>
            <div class="container-fluid p-4">
                @RenderBody()
            </div>
        </div>
    </div>
}
else
{
    @RenderBody()
}

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/app.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
