@page "{id:int}"
@model ElectionCampaignTool.Pages.Booths.EditModel
@{
    ViewData["Title"] = "Edit Booth";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil me-2"></i>Edit Booth #@Model.Booth?.BoothNumber</div>
            <div class="card-body">
                <form method="post">
                    <input asp-for="Booth!.Id" type="hidden" />
                    <input asp-for="Booth!.ConstituencyId" type="hidden" />
                    <div class="row g-3">
                        <div class="col-6">
                            <label asp-for="Booth!.BoothNumber" class="form-label fw-semibold">Booth Number</label>
                            <input asp-for="Booth!.BoothNumber" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Booth!.WardNumber" class="form-label fw-semibold">Ward</label>
                            <input asp-for="Booth!.WardNumber" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Booth!.BoothName" class="form-label fw-semibold">Booth Name</label>
                            <input asp-for="Booth!.BoothName" class="form-control" />
                        </div>
                        <div class="col-12">
                            <label asp-for="Booth!.Address" class="form-label fw-semibold">Address</label>
                            <input asp-for="Booth!.Address" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Booth!.AssignedAgentName" class="form-label fw-semibold">Agent Name</label>
                            <input asp-for="Booth!.AssignedAgentName" class="form-control" />
                        </div>
                        <div class="col-6">
                            <label asp-for="Booth!.AssignedAgentPhone" class="form-label fw-semibold">Agent Phone</label>
                            <input asp-for="Booth!.AssignedAgentPhone" class="form-control" />
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Update</button>
                        <a asp-page="/Booths/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
