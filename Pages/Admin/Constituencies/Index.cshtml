@page
@model ElectionCampaignTool.Pages.Admin.Constituencies.IndexModel
@{
    ViewData["Title"] = "Constituencies";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-auto-dismiss"><i class="bi bi-check-circle me-2"></i>@TempData["Message"]</div>
}
@if (TempData["Error"] != null)
{
    <div class="alert alert-danger alert-auto-dismiss"><i class="bi bi-x-circle me-2"></i>@TempData["Error"]</div>
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <span class="text-muted small">@Model.Constituencies.Count constituency(ies)</span>
    <a asp-page="/Admin/Constituencies/Create" class="btn btn-primary btn-sm">
        <i class="bi bi-plus-circle me-1"></i>Add Constituency
    </a>
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead class="table-light">
                    <tr>
                        <th>Name</th><th>Code</th><th>Type</th><th>State / District</th>
                        <th>Candidate</th><th>Election Date</th><th>Wards</th><th>Voters</th><th></th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var c in Model.Constituencies)
                {
                    <tr>
                        <td class="fw-semibold">@c.Name</td>
                        <td><span class="badge bg-secondary">@c.Code</span></td>
                        <td><span class="badge bg-info text-dark">@c.ElectionType</span></td>
                        <td class="small">@c.State / @c.District</td>
                        <td class="small">@(c.CandidateName ?? "—") @(!string.IsNullOrEmpty(c.PartyName) ? $"({c.PartyName})" : "")</td>
                        <td class="small">@c.ElectionDate.ToString("dd MMM yyyy")</td>
                        <td class="text-center">@(Model.WardCounts.GetValueOrDefault(c.Id, 0))</td>
                        <td class="text-center">@(Model.VoterCounts.GetValueOrDefault(c.Id, 0))</td>
                        <td>
                            <div class="d-flex gap-1">
                                <a asp-page="/Admin/Constituencies/Edit" asp-route-id="@c.Id"
                                   class="btn btn-sm btn-outline-primary py-0 px-2" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <a asp-page="/Admin/Wards/Index" asp-route-constituencyId="@c.Id"
                                   class="btn btn-sm btn-outline-secondary py-0 px-2" title="Manage Wards">
                                    <i class="bi bi-map"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" asp-route-id="@c.Id"
                                      onsubmit="return confirm('Delete constituency \'@c.Name\'? This cannot be undone.');">
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-2" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Constituencies.Any())
                {
                    <tr><td colspan="9" class="text-center text-muted py-4">No constituencies found.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
