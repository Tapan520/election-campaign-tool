@page "{id:int}"
@model ElectionCampaignTool.Pages.Admin.Wards.EditModel
@{
    ViewData["Title"] = "Edit Ward";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-pencil me-2"></i>Edit Ward</div>
            <div class="card-body">
                <form method="post">
                    <input type="hidden" asp-for="WardId" />
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Input.ConstituencyId" class="form-label fw-semibold">Constituency *</label>
                            <select asp-for="Input.ConstituencyId" asp-items="Model.ConstituencyItems" class="form-select">
                                <option value="">-- Select Constituency --</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label asp-for="Input.WardNumber" class="form-label fw-semibold">Ward Number *</label>
                            <input asp-for="Input.WardNumber" class="form-control" />
                            <span asp-validation-for="Input.WardNumber" class="text-danger small"></span>
                        </div>
                        <div class="col-md-8">
                            <label asp-for="Input.WardName" class="form-label fw-semibold">Ward Name *</label>
                            <input asp-for="Input.WardName" class="form-control" />
                            <span asp-validation-for="Input.WardName" class="text-danger small"></span>
                        </div>
                        <div class="col-12">
                            <label asp-for="Input.Description" class="form-label fw-semibold">Description</label>
                            <textarea asp-for="Input.Description" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Update</button>
                        <a asp-page="/Admin/Wards/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
