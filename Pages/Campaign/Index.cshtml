@page
@model ElectionCampaignTool.Pages.Campaign.IndexModel
@{
    ViewData["Title"] = "Campaign Events";
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">@TempData["Message"]</div>
}

<div class="d-flex justify-content-between mb-3">
    <div>
        @if (Model.IsAdmin)
        {
            <form method="get" class="d-flex gap-2 align-items-center">
                <select name="constituencyFilter" class="form-select form-select-sm" onchange="this.form.submit()" style="width:200px">
                    <option value="">All Constituencies</option>
                    @foreach (var c in Model.Constituencies)
                    {
                        <option value="@c.Id" selected="@(Model.ConstituencyFilter == c.Id)">@c.Name</option>
                    }
                </select>
            </form>
        }
    </div>
    @if (Model.CanManage)
    {
        <a asp-page="/Campaign/Create" class="btn btn-primary btn-sm"><i class="bi bi-plus-lg me-1"></i>Add Event</a>
    }
</div>

<div class="card">
    <div class="card-body p-0">
        <div class="table-responsive">
            <table class="table table-hover mb-0">
                <thead>
                    <tr><th>Title</th><th>Type</th><th>Date & Time</th><th>Location</th><th>Expected</th><th>Status</th><th></th></tr>
                </thead>
                <tbody>
                @foreach (var ev in Model.Events)
                {
                    <tr>
                        <td><div class="fw-semibold">@ev.Title</div>
                            @if (!string.IsNullOrEmpty(ev.TargetBoothNumbers))
                            {
                                <small class="text-muted">Booths: @ev.TargetBoothNumbers</small>
                            }
                        </td>
                        <td><span class="badge bg-info text-dark">@ev.EventType</span></td>
                        <td>@ev.ScheduledAt.ToString("dd MMM yy, h:mm tt")</td>
                        <td>@ev.Location</td>
                        <td>@(ev.ExpectedAttendance?.ToString() ?? "Ś")</td>
                        <td>
                            @if (ev.IsCompleted)
                            {
                                <span class="badge bg-success">Completed</span>
                            }
                            else if (ev.ScheduledAt < DateTime.Now)
                            {
                                <span class="badge bg-warning text-dark">Pending Review</span>
                            }
                            else
                            {
                                <span class="badge bg-primary">Scheduled</span>
                            }
                        </td>
                        <td>
                            <div class="d-flex gap-1">
                            <form method="post" asp-page-handler="Complete" class="d-inline">
                                <input type="hidden" name="id" value="@ev.Id" />
                                @if (!ev.IsCompleted && Model.CanManage)
                                {
                                    <button type="submit" class="btn btn-sm btn-outline-success py-0" title="Mark Complete">
                                        <i class="bi bi-check"></i>
                                    </button>
                                }
                            </form>
                            @if (Model.CanManage)
                            {
                                <a asp-page="/Campaign/Edit" asp-route-id="@ev.Id" class="btn btn-sm btn-outline-primary py-0" title="Edit">
                                    <i class="bi bi-pencil"></i>
                                </a>
                                <form method="post" asp-page-handler="Delete" class="d-inline"
                                    onsubmit="return confirm('Delete this event?')">
                                    <input type="hidden" name="id" value="@ev.Id" />
                                    <button type="submit" class="btn btn-sm btn-outline-danger py-0" title="Delete">
                                        <i class="bi bi-trash"></i>
                                    </button>
                                </form>
                            }
                            </div>
                        </td>
                    </tr>
                }
                @if (!Model.Events.Any())
                {
                    <tr><td colspan="7" class="text-center text-muted py-4">No events planned yet.</td></tr>
                }
                </tbody>
            </table>
        </div>
    </div>
</div>
