@page "{id:int}"
@model ElectionCampaignTool.Pages.Surveys.DetailsModel
@{
    ViewData["Title"] = Model.Survey.Title;
    var ratingLabels = new[] { "", "Very Negative", "Negative", "Neutral", "Positive", "Very Positive" };
    var ratingColors = new[] { "", "bg-danger", "bg-warning text-dark", "bg-secondary", "bg-info text-dark", "bg-success" };
}

@if (TempData["Message"] != null)
{
    <div class="alert alert-success alert-auto-dismiss">@TempData["Message"]</div>
}

<!-- Header -->
<div class="card mb-4">
    <div class="card-body">
        <div class="d-flex justify-content-between align-items-start flex-wrap gap-2">
            <div>
                <span class="badge @(Model.Survey.Category switch {
                    SurveyCategory.CandidateAwareness  => "bg-primary",
                    SurveyCategory.LocalIssues         => "bg-warning text-dark",
                    SurveyCategory.PartySupport        => "bg-success",
                    SurveyCategory.DevelopmentFeedback => "bg-info text-dark",
                    _                                  => "bg-secondary"
                }) mb-2">@Model.Survey.Category</span>
                <h5 class="fw-bold mb-1">@Model.Survey.Title</h5>
                <p class="text-muted mb-0">@Model.Survey.Description</p>
                @if (Model.Survey.Constituency != null)
                {
                    <small class="text-muted"><i class="bi bi-geo-alt me-1"></i>@Model.Survey.Constituency.Name</small>
                }
            </div>
            <div class="d-flex gap-2">
                @if (Model.CanManage)
                {
                    <a asp-page="/Surveys/Edit" asp-route-id="@Model.Survey.Id" class="btn btn-sm btn-outline-primary">
                        <i class="bi bi-pencil me-1"></i>Edit Survey
                    </a>
                }
                <a asp-page="/Surveys/Index" class="btn btn-sm btn-outline-secondary"><i class="bi bi-arrow-left me-1"></i>Back</a>
            </div>
        </div>
    </div>
</div>

<!-- Stats row -->
<div class="row g-3 mb-4">
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="fs-3 fw-bold text-primary">@Model.Survey.Responses.Count</div>
                <div class="small text-muted">Total Responses</div>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-center h-100">
            <div class="card-body">
                <div class="fs-3 fw-bold text-warning">@(Model.AvgRating > 0 ? Model.AvgRating.ToString("0.0") : "Ś")</div>
                <div class="small text-muted">Average Rating</div>
                <div class="mt-1">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <i class="bi @(i <= (int)Math.Round(Model.AvgRating) ? "bi-star-fill text-warning" : "bi-star text-muted") small"></i>
                    }
                </div>
            </div>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card h-100">
            <div class="card-body">
                <div class="small fw-semibold mb-2">Rating Breakdown</div>
                @foreach (var kv in Model.RatingBreakdown.OrderByDescending(x => x.Key))
                {
                    var pct = Model.Survey.Responses.Any() ? kv.Value * 100 / Model.Survey.Responses.Count : 0;
                    <div class="d-flex align-items-center gap-2 mb-1">
                        <span class="small text-nowrap" style="width:90px">@ratingLabels[kv.Key]</span>
                        <div class="progress flex-grow-1" style="height:14px">
                            <div class="progress-bar @ratingColors[kv.Key]" style="width:@pct%"></div>
                        </div>
                        <span class="small text-muted" style="width:28px">@kv.Value</span>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div class="row g-4">
    <!-- Add Response Form -->
    @if (Model.Survey.IsActive)
    {
        <div class="col-md-4">
            <div class="card">
                <div class="card-header"><i class="bi bi-plus-circle me-2"></i>Add Response</div>
                <div class="card-body">
                    <form method="post">
                        <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                        <div class="row g-2">
                            <div class="col-12">
                                <label asp-for="NewResponse.RespondentName" class="form-label fw-semibold small">Name</label>
                                <input asp-for="NewResponse.RespondentName" class="form-control form-control-sm" placeholder="Respondent name" />
                            </div>
                            <div class="col-12">
                                <label asp-for="NewResponse.RespondentPhone" class="form-label fw-semibold small">Phone</label>
                                <input asp-for="NewResponse.RespondentPhone" class="form-control form-control-sm" placeholder="Mobile number" />
                            </div>
                            <div class="col-6">
                                <label asp-for="NewResponse.Ward" class="form-label fw-semibold small">Ward</label>
                                <input asp-for="NewResponse.Ward" class="form-control form-control-sm" placeholder="Ward" />
                            </div>
                            <div class="col-6">
                                <label asp-for="NewResponse.BoothNumber" class="form-label fw-semibold small">Booth No.</label>
                                <input asp-for="NewResponse.BoothNumber" type="number" class="form-control form-control-sm" placeholder="Booth" />
                            </div>
                            <div class="col-12">
                                <label asp-for="NewResponse.Rating" class="form-label fw-semibold small">Rating (1¢5) *</label>
                                <div class="d-flex gap-1 rating-selector">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <input type="radio" class="btn-check" name="NewResponse.Rating" id="star@(i)" value="@i" />
                                        <label class="btn btn-sm btn-outline-warning" for="star@(i)" title="@ratingLabels[i]">@i</label>
                                    }
                                </div>
                            </div>
                            <div class="col-12">
                                <label asp-for="NewResponse.Feedback" class="form-label fw-semibold small">Feedback</label>
                                <textarea asp-for="NewResponse.Feedback" class="form-control form-control-sm" rows="3"
                                    placeholder="Voter comments..."></textarea>
                            </div>
                        </div>
                        <div class="mt-3">
                            <button type="submit" class="btn btn-primary btn-sm w-100"><i class="bi bi-save me-1"></i>Save Response</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    }

    <!-- Responses table -->
    <div class="col-md-@(Model.Survey.IsActive ? "8" : "12")">
        <div class="card">
            <div class="card-header"><i class="bi bi-list-ul me-2"></i>All Responses (@Model.Survey.Responses.Count)</div>
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead>
                            <tr><th>Respondent</th><th>Ward / Booth</th><th>Rating</th><th>Feedback</th><th>Date</th><th></th></tr>
                        </thead>
                        <tbody>
                        @foreach (var r in Model.Survey.Responses)
                        {
                            <tr>
                                <td>
                                    <div class="fw-semibold">@(r.RespondentName ?? "Anonymous")</div>
                                    @if (!string.IsNullOrEmpty(r.RespondentPhone))
                                    {
                                        <small class="text-muted">@r.RespondentPhone</small>
                                    }
                                </td>
                                <td>
                                    @if (!string.IsNullOrEmpty(r.Ward)) { <div class="small">@r.Ward</div> }
                                    @if (r.BoothNumber.HasValue) { <small class="text-muted">Booth @r.BoothNumber</small> }
                                </td>
                                <td>
                                    <span class="badge @ratingColors[Math.Clamp(r.Rating, 1, 5)]">
                                        @r.Rating ? @ratingLabels[Math.Clamp(r.Rating, 1, 5)]
                                    </span>
                                </td>
                                <td class="small">@(r.Feedback ?? "Ś")</td>
                                <td class="small text-muted">@r.RespondedAt.ToString("dd MMM yy")</td>
                                <td>
                                    @if (Model.CanManage)
                                    {
                                        <form method="post" asp-page-handler="DeleteResponse"
                                            asp-route-id="@Model.Survey.Id"
                                            onsubmit="return confirm('Delete this response?')">
                                            <input type="hidden" name="responseId" value="@r.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0" title="Delete">
                                                <i class="bi bi-trash"></i>
                                            </button>
                                        </form>
                                    }
                                </td>
                            </tr>
                        }
                        @if (!Model.Survey.Responses.Any())
                        {
                            <tr><td colspan="6" class="text-center text-muted py-4">No responses yet.</td></tr>
                        }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    </div>
</div>
