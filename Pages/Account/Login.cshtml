@page
@model ElectionCampaignTool.Pages.Account.LoginModel
@{
    ViewData["Title"] = "Login";
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login - Election Campaign Tool</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css" />
    <link rel="stylesheet" href="~/css/app.css" />
</head>
<body>
<div class="login-wrapper">
    <div class="login-card card p-4">
        <div class="text-center mb-4">
            <i class="bi bi-bar-chart-fill text-warning fs-1"></i>
            <h4 class="mt-2 mb-0 fw-bold">Election Campaign Tool</h4>
            <small class="text-muted">Sign in to your campaign dashboard</small>
        </div>
        @if (!string.IsNullOrEmpty(Model.ErrorMessage))
        {
            <div class="alert alert-danger py-2">
                <i class="bi bi-exclamation-circle me-1"></i>@Model.ErrorMessage
            </div>
        }
        <form method="post">
            <div class="mb-3">
                <label asp-for="Input.Email" class="form-label fw-semibold">Email</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-envelope"></i></span>
                    <input asp-for="Input.Email" class="form-control" placeholder="you@election.com" autofocus />
                </div>
                <span asp-validation-for="Input.Email" class="text-danger small"></span>
            </div>
            <div class="mb-4">
                <label asp-for="Input.Password" class="form-label fw-semibold">Password</label>
                <div class="input-group">
                    <span class="input-group-text"><i class="bi bi-lock"></i></span>
                    <input asp-for="Input.Password" class="form-control" placeholder="••••••••" />
                </div>
                <span asp-validation-for="Input.Password" class="text-danger small"></span>
            </div>
            <div class="mb-3 form-check">
                <input asp-for="Input.RememberMe" class="form-check-input" />
                <label asp-for="Input.RememberMe" class="form-check-label">Remember me</label>
            </div>
            <button type="submit" class="btn btn-primary w-100 fw-semibold">
                <i class="bi bi-box-arrow-in-right me-1"></i>Sign In
            </button>
        </form>
        @* <hr class="my-3" />
        <div class="text-center small text-muted">
            <strong>Demo Accounts:</strong><br/>
            admin@election.com / Admin@123<br/>
            manager@election.com / Manager@123<br/>
            worker@election.com / Worker@123
        </div> *@
    </div>
</div>
<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
