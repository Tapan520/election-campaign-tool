@page
@model Nirvachak_AI.Pages.Expenses.CreateModel
@{
    ViewData["Title"] = "Add Expense";
}
<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card">
            <div class="card-header"><i class="bi bi-cash-coin me-2"></i>Record Expense</div>
            <div class="card-body">
                <form method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger small"></div>
                    <div class="row g-3">
                        <div class="col-12">
                            <label asp-for="Expense.Description" class="form-label fw-semibold">Description *</label>
                            <input asp-for="Expense.Description" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Expense.Category" class="form-label fw-semibold">Category *</label>
                            <select asp-for="Expense.Category" class="form-select"
                                asp-items="Html.GetEnumSelectList<ExpenseCategory>()"></select>
                        </div>
                        @if (Model.IsAdmin)
                        {
                        <div class="col-md-6">
                            <label for="SelectedConstituencyId" class="form-label fw-semibold">Constituency *</label>
                            <select id="SelectedConstituencyId" name="SelectedConstituencyId" class="form-select"
                                asp-items="Model.ConstituencyList">
                                <option value="">-- Select Constituency --</option>
                            </select>
                        </div>
                        }
                        <div class="col-md-6">
                            <label asp-for="Expense.Amount" class="form-label fw-semibold">Amount (?) *</label>
                            <input asp-for="Expense.Amount" type="number" step="0.01" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Expense.ExpenseDate" class="form-label fw-semibold">Date *</label>
                            <input asp-for="Expense.ExpenseDate" type="date" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Expense.PayeeName" class="form-label fw-semibold">Payee Name</label>
                            <input asp-for="Expense.PayeeName" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <label asp-for="Expense.VoucherNumber" class="form-label fw-semibold">Voucher No.</label>
                            <input asp-for="Expense.VoucherNumber" class="form-control" />
                        </div>
                        <div class="col-md-6">
                            <div class="form-check mt-4">
                                <input asp-for="Expense.IsECCompliant" class="form-check-input" />
                                <label asp-for="Expense.IsECCompliant" class="form-check-label fw-semibold">EC Compliant</label>
                            </div>
                        </div>
                        <div class="col-12">
                            <label asp-for="Expense.Notes" class="form-label fw-semibold">Notes</label>
                            <textarea asp-for="Expense.Notes" class="form-control" rows="2"></textarea>
                        </div>
                    </div>
                    <div class="mt-3 d-flex gap-2">
                        <button type="submit" class="btn btn-primary"><i class="bi bi-save me-1"></i>Save</button>
                        <a asp-page="/Expenses/Index" class="btn btn-outline-secondary">Cancel</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>
